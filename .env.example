# ── Backend env vars (set in Vercel → Project → Settings → Environment Variables) ──
# Never commit real values. The app refuses to start the API without JWT_SECRET
# and APP_ENCRYPTION_KEY.

# Postgres connection. Added automatically when you attach Vercel Postgres / Neon.
# For Supabase/other, paste the pooled connection string here.
POSTGRES_URL=

# JWT signing secret for login tokens.  Generate:  openssl rand -base64 48
JWT_SECRET=

# AES-256-GCM key that encrypts secrets at rest (OpenWA api key, exchange secrets).
# MUST be exactly 64 hex characters.  Generate:  openssl rand -hex 32
APP_ENCRYPTION_KEY=

# Optional: require this token (header x-setup-token) to call POST /api/init.
# Recommended in production.  Generate:  openssl rand -hex 16
SETUP_TOKEN=
